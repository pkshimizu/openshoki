import { Button, CheckBox, ScrollView, SpinBox, Palette } from "std-widgets.slint";

// タイポグラフィと淡色のトークン。意味のある繰り返し値を 1 箇所に集約し、トーン調整時の
// 追従漏れ・不整合を防ぐ（余白やインデントの一回きりの値は各所に直書きのままでよい）。
global Style {
    out property <length> title-size: 15px; // ウィンドウタイトル
    out property <length> heading-size: 12px; // セクション見出し
    out property <length> body-size: 13px; // 本文ラベル
    out property <length> caption-size: 12px; // 補助テキスト（パス・注記）
    out property <int> semibold: 600;
    out property <float> muted-alpha: 0.4; // 補助テキストの淡色化（transparentize の引数）
    out property <float> disabled-opacity: 0.4; // 従属ブロック無効時の淡色化（opacity）
}

// 設定項目のまとまりを表すセクション枠。GroupBox の既定描画ではなく「角丸・1px 枠線・塗りなし」の
// 箱＋内側見出しで組み、配色は Palette でライト/ダークに追従させる（色をハードコードしない）。
component SettingsSection inherits Rectangle {
    in property <string> title;
    border-width: 1px;
    border-color: Palette.border;
    border-radius: 8px;
    background: transparent;
    VerticalLayout {
        padding: 14px;
        spacing: 10px;
        Text {
            text: root.title;
            font-size: Style.heading-size;
            font-weight: Style.semibold;
            color: Palette.foreground;
        }

        @children
    }
}

// 常駐アプリの設定画面。トレイメニューから表示する。
// 「録音ファイルの保存先」「登録アプリのマイク使用で自動録音」「自動停止の待ち時間」
// 「録音停止時の自動文字起こし」を、意味のまとまりでセクション化して設定できる。
export component AppWindow inherits Window {
    title: "openshoki";
    // preferred だけだと中身の最小高さ（≒0）に引っ張られて潰れるため、min も指定する。
    // 幅・高さは src/main.rs の WINDOW_WIDTH/HEIGHT と一致させること（片方だけ変えない）。
    // 幅は 420 固定。高さは新レイアウト（3 セクション）に合わせた値。
    min-width: 420px;
    min-height: 680px;
    preferred-width: 420px;
    preferred-height: 680px;

    // 現在の録音ファイル保存先（表示用）。Rust 側から設定する。
    in property <string> recording-dir;
    // 「登録アプリのマイク使用で自動録音」の ON/OFF。起動時に Rust 側が設定値で初期化し、以後は
    // トグル操作で Slint が状態を保持する（in-out）。
    in-out property <bool> auto-record-app;
    // 登録アプリの表示名一覧（Rust 側の app_mic_triggers を反映）。
    in property <[string]> app-list;
    // 自動停止のデバウンス秒数。起動時に Rust 側が設定値で初期化し、以後は SpinBox で編集する（in-out）。
    // 範囲は minimum/maximum（下の SpinBox）で制限し、Rust 側の DEBOUNCE_MIN/MAX_SECS と一致させる。
    in-out property <int> auto-stop-debounce-secs;
    // 「録音停止時に自動文字起こし」の ON/OFF。起動時に Rust 側が設定値で初期化し、以後は
    // トグル操作で Slint が状態を保持する（in-out。保存失敗時は Rust 側が書き戻す）。
    in-out property <bool> auto-transcribe;
    // 「フォルダを選択」押下。Rust 側でネイティブのフォルダ選択ダイアログを開く。
    callback choose-folder();
    // アプリのマイク使用 自動録音トグルの切り替え。新しい ON/OFF を渡し、Rust 側で設定へ永続化する。
    callback toggle-auto-record-app(bool);
    // 自動停止デバウンス秒数の変更。新しい秒数を渡し、Rust 側で範囲を丸めて永続化する。
    callback change-auto-stop-debounce(int);
    // 「アプリを追加」押下。Rust 側で .app 選択ダイアログを開き、登録する。
    callback add-app();
    // 登録アプリの削除。一覧のインデックスを渡す。
    callback remove-app(int);
    // 自動文字起こしトグルの切り替え。新しい ON/OFF を渡し、Rust 側で設定へ永続化する。
    callback toggle-auto-transcribe(bool);

    VerticalLayout {
        alignment: start;
        spacing: 14px;
        padding-left: 20px;
        padding-right: 20px;
        padding-top: 18px;
        padding-bottom: 22px;

        Text {
            text: "openshoki Settings";
            font-size: Style.title-size;
            font-weight: Style.semibold;
            horizontal-alignment: center;
        }

        // --- Recording: 保存先フォルダ ---
        SettingsSection {
            title: "Recording";
            Text {
                text: "Folder";
                font-size: Style.body-size;
                color: Palette.foreground;
            }
            // パス（折り返し）とボタン（折り返さない）を同一行・両端揃えにする。
            HorizontalLayout {
                spacing: 12px;
                Text {
                    text: root.recording-dir;
                    wrap: word-wrap;
                    font-size: Style.caption-size;
                    color: Palette.foreground.transparentize(Style.muted-alpha);
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Button {
                    text: "Choose Folder";
                    horizontal-stretch: 0;
                    clicked => {
                        root.choose-folder();
                    }
                }
            }
        }

        // --- Auto-record: 登録アプリのマイク使用に連動 ---
        SettingsSection {
            title: "Auto-Record";
            // 複数行ラベルにするため、CheckBox（テキストなし）＋折り返し Text を横並びにする。
            // トグルはチェックボックス本体で行う。
            HorizontalLayout {
                spacing: 8px;
                CheckBox {
                    checked: root.auto-record-app;
                    toggled => {
                        root.auto-record-app = self.checked;
                        root.toggle-auto-record-app(self.checked);
                    }
                }

                Text {
                    text: "Auto-record while a registered app uses the mic — for calls (macOS 14.4+)";
                    wrap: word-wrap;
                    font-size: Style.body-size;
                    color: Palette.foreground;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }

            // 従属コントロール（delay・Trigger apps）を左インデントし、自動録音 OFF のときは
            // 淡色化（opacity）＋各操作の無効化（enabled）で従属関係を示す。無効化条件は
            // enabled-gate に一本化し、opacity と各 enabled が食い違わないようにする。
            deps := Rectangle {
                property <bool> enabled-gate: root.auto-record-app;
                opacity: enabled-gate ? 1.0 : Style.disabled-opacity;
                VerticalLayout {
                    padding-left: 23px;
                    padding-top: 6px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Auto-stop delay (seconds)";
                            font-size: Style.body-size;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            color: Palette.foreground;
                        }

                        SpinBox {
                            // 範囲は src/config.rs の DEBOUNCE_MIN_SECS / DEBOUNCE_MAX_SECS と一致させること。
                            minimum: 1;
                            maximum: 60;
                            value: root.auto-stop-debounce-secs;
                            // 途絶が有効なのは自動録音 ON のときだけなので、OFF では無効化する。
                            enabled: deps.enabled-gate;
                            edited(secs) => {
                                root.auto-stop-debounce-secs = secs;
                                root.change-auto-stop-debounce(secs);
                            }
                        }
                    }

                    Text {
                        text: "Trigger apps";
                        font-size: Style.body-size;
                        color: Palette.foreground;
                    }

                    // フィールド風のリストボックス（入力欄と同じ背景＋角丸＋枠）。空でも枠を保つ。
                    Rectangle {
                        height: 96px;
                        border-width: 1px;
                        border-color: Palette.border;
                        border-radius: 6px;
                        background: Palette.control-background;
                        clip: true;
                        ScrollView {
                            VerticalLayout {
                                alignment: start;
                                for name[i] in root.app-list: VerticalLayout {
                                    // 2 行目以降の先頭に行区切りの罫線を置く（先頭行は 0px で出さない）。
                                    Rectangle {
                                        height: i > 0 ? 1px : 0px;
                                        background: Palette.border;
                                    }

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 12px;
                                        padding-top: 6px;
                                        padding-bottom: 6px;
                                        spacing: 8px;
                                        Text {
                                            text: name;
                                            font-size: Style.body-size;
                                            color: Palette.foreground;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                            overflow: elide;
                                        }

                                        Button {
                                            text: "Remove";
                                            enabled: deps.enabled-gate;
                                            clicked => {
                                                root.remove-app(i);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: start;
                        Button {
                            text: "Add app…";
                            enabled: deps.enabled-gate;
                            clicked => {
                                root.add-app();
                            }
                        }
                    }
                }
            }
        }

        // --- Transcription: 録音停止時の自動文字起こし ---
        SettingsSection {
            title: "Transcription";
            HorizontalLayout {
                spacing: 8px;
                CheckBox {
                    checked: root.auto-transcribe;
                    toggled => {
                        root.auto-transcribe = self.checked;
                        root.toggle-auto-transcribe(self.checked);
                    }
                }

                Text {
                    text: "Transcribe recordings on stop — on-device Whisper";
                    wrap: word-wrap;
                    font-size: Style.body-size;
                    color: Palette.foreground;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }

            Text {
                // モデルは内蔵（初回に自動ダウンロード）。これまで通信ゼロだったアプリで唯一の
                // 外部通信になるため、接続先と「音声は送らない」ことを明示する（透明性）。
                text: "First use downloads the speech model (about 465 MB) from Hugging Face — audio is never uploaded";
                wrap: word-wrap;
                font-size: Style.caption-size;
                color: Palette.foreground.transparentize(Style.muted-alpha);
            }
        }
    }
}
