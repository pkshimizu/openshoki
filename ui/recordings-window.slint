import { Button, ListView, ScrollView, Palette } from "std-widgets.slint";
import { Style } from "style.slint";

// 文字起こしの表示状態。Rust 側（main.rs の transcript_display_status）がワーカーの
// 進行状況と JSON の有無から合成して詰める。
export enum TranscriptStatus {
    not-transcribed,
    transcribing,
    done,
    failed,
}

// 一覧の 1 行分。Rust の recordings::RecordingSession から詰める。
export struct SessionRow {
    datetime: string,
    has-mic: bool,
    has-system: bool,
    transcript-status: TranscriptStatus,
}

// トランスクリプトの表示 1 行分。Rust の transcript::TranscriptSegment から詰める
// （speaker は "Mic" / "System"、time は "mm:ss"、1 時間以上は "h:mm:ss"）。配色判定はラベル文字列の
// 比較でなく is-mic で行う（ラベルを変えても配色が壊れないように）。クリック時のシーク秒は
// Rust 側が index で解決する。
export struct TranscriptRow {
    speaker: string,
    is-mic: bool,
    time: string,
    text: string,
}

// 音源バッジ（`Mic` / `System`）。選択行では白アウトライン、非選択では補助色アウトライン。
component SourceBadge inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    border-radius: 4px;
    border-width: 1px;
    border-color: selected ? Style.on-accent-foreground : Palette.border;
    background: transparent;
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        padding-top: 2px;
        padding-bottom: 2px;
        Text {
            text: root.label;
            font-size: Style.badge-size;
            font-weight: Style.semibold;
            color: root.selected ? Style.on-accent-foreground : Palette.foreground.transparentize(Style.muted-alpha);
        }
    }
}

// トランスクリプトの話者バッジ。Mic はアクセント色背景＋白文字、System はニュートラル背景。
component SpeakerBadge inherits Rectangle {
    in property <string> label;
    in property <bool> accent;
    border-radius: 4px;
    background: accent ? Palette.accent-background : Palette.border;
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        padding-top: 2px;
        padding-bottom: 2px;
        Text {
            text: root.label;
            font-size: Style.badge-size;
            font-weight: Style.semibold;
            color: root.accent ? Style.on-accent-foreground : Palette.foreground;
        }
    }
}

// 破壊的操作用のボタン。std-widgets の Button は文字色・背景色を変えられないため、同等の
// 見た目を Rectangle + TouchArea で作る。filled=false はヘッダの Delete（赤文字・通常背景）、
// filled=true は確認モーダルの確定ボタン（赤背景・白文字）。
component DangerButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> filled: false;

    callback clicked();

    border-radius: 6px;
    border-width: root.filled ? 0 : 1px;
    border-color: Palette.border;
    background: root.filled
        ? (touch.pressed && root.enabled ? Style.danger.darker(15%) : Style.danger)
        : (touch.pressed && root.enabled
            ? Palette.control-background.darker(8%)
            : Palette.control-background);
    opacity: root.enabled ? 1.0 : 0.5;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 5px;
        padding-bottom: 5px;
        Text {
            text: root.text;
            font-size: Style.body-size;
            font-weight: root.filled ? Style.semibold : 400;
            color: root.filled ? Style.on-accent-foreground : Style.danger;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

// トレイの「Recordings…」から開く録音一覧ウィンドウ。左＝セッション一覧、右＝再生と文字起こし。
// 配色は Palette でライト/ダークに追従し、サイズ・淡色は共有の Style トークンを使う
// （選択行の白文字はアクセント固定背景のため Style.on-accent-foreground）。
export component RecordingsWindow inherits Window {
    title: "Recordings";
    // 幅・高さは src/main.rs の RECORDINGS_WIDTH/HEIGHT と一致させること（片方だけ変えない）。
    min-width: 720px;
    min-height: 540px;
    preferred-width: 720px;
    preferred-height: 540px;

    // セッション一覧（新しい順）。Rust 側が list_sessions の結果で更新する。
    in property <[SessionRow]> sessions;
    // 選択中セッションの一覧インデックス。未選択は -1。行クリックで更新し select-session を呼ぶ。
    in-out property <int> selected-index: -1;
    // 選択セッションの詳細（Rust 側が選択時に更新する）。
    in property <bool> has-selection;
    in property <string> detail-datetime;
    in property <string> detail-summary;
    // 選択中セッションの文字起こし状態テキスト（Rust 側が組み立てる。例: Transcribed /
    // Transcribing… / Transcription failed / Not transcribed）。
    in property <string> detail-transcript-text;
    // 選択中セッションが文字起こし中か（Transcribe ボタンの無効化に使う）。
    in property <bool> detail-transcribing;
    // 選択セッションのトランスクリプト（mic.json / system.json をマージしたもの。新→旧でなく時刻順）。
    // 空なら Transcript セクションは「Not Transcribed Yet」に縮退表示する。
    in property <[TranscriptRow]> segments;
    // 現在の再生位置に対応するセグメントの index（ハイライト対象。-1 は該当なし）。
    in property <int> current-segment: -1;
    // 選択セッションが再生可能か（両音源は mix.mp3 生成済み、単一音源は常に可）。false なら
    // 再生ボタンを無効化する。
    in property <bool> playable;
    // 再生状態。playing は Play/Pause ラベルの切替、time-text は "mm:ss / mm:ss"、
    // progress は 0.0〜1.0 の進捗（表示のみ・ドラッグ不可）。
    in property <bool> playing;
    in property <string> time-text;
    in property <float> progress;
    // 削除の確認モーダルの表示状態。Delete 押下で開き、Cancel / 確定で閉じる（Slint 内で完結）。
    in-out property <bool> show-delete-confirm: false;

    // 行クリックでの選択通知。Rust 側で詳細更新・再生対象のロードを行う。
    callback select-session(int);
    // 再生/一時停止トグルと停止。
    callback play-pause();
    callback stop();
    // トランスクリプトのセグメントクリック。その開始秒へ再生位置をスキップする（index を渡す）。
    callback seek-to-segment(int);
    // 「Transcribe」押下。選択中セッションの文字起こしを（再）実行する。インデックスを渡す。
    callback transcribe-session(int);
    // 確認モーダルの Delete 押下。選択中セッションをゴミ箱へ移動する（インデックスを渡す）。
    callback delete-session(int);

    HorizontalLayout {
        padding: 16px;
        spacing: 14px;

        // --- 左ペイン: セッション一覧 ---
        Rectangle {
            width: 236px;
            border-width: 1px;
            border-color: Palette.border;
            border-radius: 8px;
            background: Palette.control-background;
            clip: true;

            if root.sessions.length == 0: VerticalLayout {
                alignment: center;
                padding: 24px;
                spacing: 6px;
                Text {
                    text: "No Recordings Yet";
                    font-size: Style.body-size;
                    font-weight: Style.semibold;
                    horizontal-alignment: center;
                    color: Palette.foreground;
                }

                Text {
                    text: "Recordings you make will appear here.";
                    font-size: Style.caption-size;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                    color: Palette.foreground.transparentize(Style.muted-alpha);
                }
            }
            if root.sessions.length > 0: ScrollView {
                VerticalLayout {
                    alignment: start;
                    for row[i] in root.sessions: Rectangle {
                        // 行間の区切り罫線（先頭行は出さない）。
                        VerticalLayout {
                            Rectangle {
                                height: i > 0 ? 1px : 0px;
                                background: Palette.border;
                            }

                            rowbg := Rectangle {
                                // 選択状態は id で参照する（レイアウトを跨ぐ parent 参照は Slint で
                                // 使えないため）。
                                property <bool> selected: i == root.selected-index;
                                background: rowbg.selected ? Palette.accent-background : transparent;
                                TouchArea {
                                    clicked => {
                                        root.selected-index = i;
                                        root.select-session(i);
                                    }
                                }

                                VerticalLayout {
                                    padding-left: 11px;
                                    padding-right: 11px;
                                    padding-top: 8px;
                                    padding-bottom: 8px;
                                    spacing: 5px;
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: row.datetime;
                                            font-size: Style.body-size;
                                            font-weight: Style.semibold;
                                            color: rowbg.selected ? Style.on-accent-foreground : Palette.foreground;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                        // 文字起こしの状態を表すドット（前=透明で場所だけ確保 /
                                        // 中=淡色 / 完了=アクセント / 失敗=警告色）。
                                        Rectangle {
                                            width: 6px;
                                            height: 6px;
                                            border-radius: 3px;
                                            background: row.transcript-status == TranscriptStatus.done
                                                ? (rowbg.selected ? Style.on-accent-foreground : Palette.accent-background)
                                                : row.transcript-status == TranscriptStatus.transcribing
                                                    ? (rowbg.selected ? Style.on-accent-foreground : Palette.foreground).transparentize(Style.muted-alpha)
                                                    : row.transcript-status == TranscriptStatus.failed ? Style.danger : transparent;
                                        }
                                    }

                                    HorizontalLayout {
                                        alignment: start;
                                        spacing: 5px;
                                        if row.has-mic: SourceBadge {
                                            label: "Mic";
                                            selected: rowbg.selected;
                                        }
                                        if row.has-system: SourceBadge {
                                            label: "System";
                                            selected: rowbg.selected;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // --- 右ペイン: 詳細（再生・文字起こし） ---
        Rectangle {
            horizontal-stretch: 1;
            // 未選択（録音ゼロ含む）のときは淡色化して非活性にする。
            opacity: root.has-selection ? 1.0 : Style.disabled-opacity;

            if !root.has-selection: Text {
                text: "No Recording Selected";
                font-size: Style.body-size;
                horizontal-alignment: center;
                vertical-alignment: center;
                color: Palette.foreground.transparentize(Style.muted-alpha);
            }

            // alignment は既定（stretch）にし、余った高さを Transcript セクション
            // （vertical-stretch: 1）へ与える。alignment: start だと全子要素が推奨サイズに
            // 縮み、中身が可変の Transcript の箱が見出しだけに潰れる。
            if root.has-selection: VerticalLayout {
                spacing: 12px;

                // ヘッダ: 日時・音源要約と、文字起こしの状態＋再実行ボタン。
                HorizontalLayout {
                    vertical-stretch: 0;
                    spacing: 12px;
                    VerticalLayout {
                        spacing: 3px;
                        horizontal-stretch: 1;
                        Text {
                            text: root.detail-datetime;
                            font-size: Style.detail-title-size;
                            font-weight: Style.semibold;
                            color: Palette.foreground;
                        }

                        Text {
                            text: root.detail-summary;
                            font-size: Style.caption-size;
                            color: Palette.foreground.transparentize(Style.muted-alpha);
                        }

                        Text {
                            text: root.detail-transcript-text;
                            font-size: Style.caption-size;
                            color: Palette.foreground.transparentize(Style.muted-alpha);
                        }
                    }

                    VerticalLayout {
                        alignment: start;
                        horizontal-stretch: 0;
                        spacing: 8px;
                        Button {
                            text: "Transcribe";
                            // 実行中（キュー待ち含む）は多重投入を防ぐ。完了済み・失敗・未実施の
                            // いずれからも（再）実行できる（言語・モデル変更後のやり直し用途）。
                            enabled: !root.detail-transcribing;
                            clicked => {
                                root.transcribe-session(root.selected-index);
                            }
                        }

                        DangerButton {
                            text: "Delete";
                            // 文字起こし中はワーカーが対象ファイルを読んでいるため削除させない
                            // （Transcribe と同じ縮退表現）。
                            enabled: !root.detail-transcribing;
                            clicked => {
                                root.show-delete-confirm = true;
                            }
                        }
                    }
                }

                // Playback セクション。
                Rectangle {
                    vertical-stretch: 0;
                    border-width: 1px;
                    border-color: Palette.border;
                    border-radius: 8px;
                    VerticalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        padding-top: 12px;
                        padding-bottom: 14px;
                        spacing: 11px;
                        Text {
                            text: "Playback";
                            font-size: Style.heading-size;
                            font-weight: Style.semibold;
                            color: Palette.foreground;
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            Button {
                                text: root.playing ? "Pause" : "Play";
                                enabled: root.playable;
                                clicked => {
                                    root.play-pause();
                                }
                            }

                            Button {
                                text: "Stop";
                                enabled: root.playable;
                                clicked => {
                                    root.stop();
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: root.time-text;
                                font-size: Style.caption-size;
                                vertical-alignment: center;
                                color: Palette.foreground.transparentize(Style.muted-alpha);
                            }
                        }

                        // 進捗バー（表示のみ）。トラック＋アクセントの塗り。
                        Rectangle {
                            height: 5px;
                            border-radius: 3px;
                            background: Palette.border;
                            clip: true;
                            Rectangle {
                                x: 0;
                                width: parent.width * min(max(root.progress, 0.0), 1.0);
                                height: parent.height;
                                border-radius: 3px;
                                background: Palette.accent-background;
                            }
                        }
                    }
                }

                // Transcript セクション。セグメントを時刻順に表示し、現在再生位置をハイライト、
                // クリックでその開始秒へシークする。未生成・破損は「Not Transcribed Yet」に縮退。
                Rectangle {
                    vertical-stretch: 1;
                    border-width: 1px;
                    border-color: Palette.border;
                    border-radius: 8px;
                    VerticalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 10px;
                        Text {
                            text: "Transcript";
                            font-size: Style.heading-size;
                            font-weight: Style.semibold;
                            color: Palette.foreground;
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            clip: true;

                            // 文字起こしがあればセグメント一覧、無ければ縮退表示。長時間録音では
                            // セグメントが数千件になり得るため、可視範囲だけ生成する ListView を使う
                            // （ScrollView + for は全行を即時生成し、選択時のヒッチにつながる）。
                            if root.segments.length > 0: ListView {
                                for seg[i] in root.segments: Rectangle {
                                    // 現在再生位置のセグメントをハイライト（淡色背景＋左 3px 罫線）。
                                    property <bool> active: i == root.current-segment;
                                    background: active ? Style.segment-highlight : transparent;
                                    // ListView の行は自身の高さを明示する（word-wrap する本文の
                                    // 実高さに追従させる）。
                                    height: row-content.preferred-height;
                                    TouchArea {
                                        clicked => {
                                            root.seek-to-segment(i);
                                        }
                                    }

                                    row-content := HorizontalLayout {
                                        // 左端のアクセント罫線（active のときだけ幅を持つ）。
                                        Rectangle {
                                            width: active ? 3px : 0px;
                                            background: Palette.accent-background;
                                        }

                                        VerticalLayout {
                                            padding-left: 8px;
                                            padding-right: 6px;
                                            padding-top: 6px;
                                            padding-bottom: 6px;
                                            spacing: 3px;
                                            HorizontalLayout {
                                                alignment: start;
                                                spacing: 7px;
                                                SpeakerBadge {
                                                    label: seg.speaker;
                                                    accent: seg.is-mic;
                                                }

                                                Text {
                                                    text: seg.time;
                                                    font-size: Style.caption-size;
                                                    vertical-alignment: center;
                                                    color: Palette.foreground.transparentize(Style.muted-alpha);
                                                }
                                            }

                                            Text {
                                                text: seg.text;
                                                wrap: word-wrap;
                                                font-size: Style.body-size;
                                                color: Palette.foreground;
                                            }
                                        }
                                    }
                                }
                            }
                            if root.segments.length == 0: Text {
                                text: "Not Transcribed Yet";
                                font-size: Style.body-size;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                color: Palette.foreground.transparentize(Style.muted-alpha);
                            }
                        }
                    }
                }
            }
        }
    }

    // 削除の確認モーダル。ウィンドウ内オーバーレイでテーマに追従する（`docs/plans` #66 の
    // デザイン準拠）。スクリムがクリックを吸収し、背後の一覧・ボタンは操作できない。
    // 閉じる操作は Cancel（何もしない）か Delete（削除を依頼して閉じる）のみ。
    if root.show-delete-confirm: Rectangle {
        background: #000000.transparentize(0.65);

        TouchArea { }

        Rectangle {
            width: 320px;
            height: dialog-layout.preferred-height;
            background: Palette.alternate-background;
            border-width: 1px;
            border-color: Palette.border;
            border-radius: 12px;

            dialog-layout := VerticalLayout {
                padding: 22px;
                padding-bottom: 16px;
                spacing: 7px;

                Text {
                    text: "Delete This Recording?";
                    font-size: Style.detail-title-size;
                    font-weight: Style.semibold;
                    color: Palette.foreground;
                    horizontal-alignment: center;
                }

                Text {
                    text: "The recording will be moved to the Trash.";
                    font-size: Style.caption-size;
                    color: Palette.foreground.transparentize(Style.muted-alpha);
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    padding-top: 11px;
                    spacing: 10px;

                    Button {
                        text: "Cancel";
                        horizontal-stretch: 1;
                        clicked => {
                            root.show-delete-confirm = false;
                        }
                    }

                    DangerButton {
                        text: "Delete";
                        filled: true;
                        horizontal-stretch: 1;
                        clicked => {
                            root.show-delete-confirm = false;
                            root.delete-session(root.selected-index);
                        }
                    }
                }
            }
        }
    }
}
